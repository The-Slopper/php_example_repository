{
  "name": "example/php-example-repository",
  "description": "Repository pattern example: data-access abstraction isolating persistence from the domain.",
  "type": "project",
  "license": "MIT",
  "keywords": ["reference", "example", "platform"],
  "homepage": "https://git.example.com/php-example-repository",
  "authors": [
    { "name": "Engineering Team", "email": "engineering@example.com", "role": "Maintainer" }
  ],
  "require": { "php": ">=8.3" },
  "require-dev": { "phpunit/phpunit": "^11" },
  "autoload": { "psr-4": { "App\\": "src/" } },
  "autoload-dev": { "psr-4": { "Tests\\": "tests/" } },
  "scripts": { "test": "phpunit", "coverage": "phpunit --coverage-text" }
}
